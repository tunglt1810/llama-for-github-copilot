# Local LLM Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and source it, or add the "Claude Code" block to your ~/.zshrc
#
#   cp .env.example .env
#   source .env

# ── llama-server ──────────────────────────────────────────────────────────────
LLAMA_HOST=127.0.0.1
LLAMA_PORT=18888

# ── LiteLLM proxy ─────────────────────────────────────────────────────────────
LITELLM_HOST=127.0.0.1
LITELLM_PORT=4000

# ── Claude Code integration ───────────────────────────────────────────────────
# Add these to your ~/.zshrc (or run `source .env` before using `claude`)
#
# Routes Claude Code CLI → LiteLLM proxy → llama-server
export ANTHROPIC_BASE_URL=http://127.0.0.1:4000
export ANTHROPIC_API_KEY=local-key

# Tell Claude Code to use the "local-llm" model alias defined in config/litellm.yaml
export ANTHROPIC_DEFAULT_OPUS_MODEL=local-llm
export ANTHROPIC_DEFAULT_SONNET_MODEL=local-llm
export ANTHROPIC_DEFAULT_HAIKU_MODEL=local-llm

# ── GitHub Copilot note ───────────────────────────────────────────────────────
# Run `make run` to start the Go-based Ollama proxy on port 11434.
# GitHub Copilot (VS Code) → Settings → "Copilot: Ollama" → URL: http://localhost:11434
# Requires Ollama >= 0.6.4 — the proxy reports version "0.6.4" for compatibility.
# The proxy serves:
#   GET  /api/version  → {"version":"0.6.4"}
#   GET  /api/tags     → available models
#   POST /api/chat     → translates to llama-server /v1/chat/completions
#   /v1/*              → pass-through (OpenAI-compatible)
OLLAMA_PROXY_HOST=127.0.0.1
OLLAMA_PROXY_PORT=11434
# It provides the same inline autocomplete + chat panel experience.
