{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Launch llama-wrapper",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/cmd/llama-proxy",
			"output": "${workspaceFolder}/bin/llama-proxy",
			"envFile": "${workspaceFolder}/.env",
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"preLaunchTask": "Terminate Old Process",
			"postDebugTask": "Terminate Old Process",
			"env": {
				"PORT": "11434",
				"RUN_MODE": "llama-server-wrapper",
				"UPSTREAM_BASE": "http://127.0.0.1:50000",
				"LLAMA_SERVER_ARGS__HOST": "127.0.0.1",
				"LLAMA_SERVER_ARGS__PORT": "50000",
			}
		},
		{
			"name": "Launch llama-proxy",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/cmd/llama-proxy",
			"output": "${workspaceFolder}/bin/llama-proxy",
			"envFile": "${workspaceFolder}/.env",
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"env": {
				"PORT": "28888",
				"RUN_MODE": "proxy-only",
				"UPSTREAM_BASE": "http://127.0.0.1:50000",
				"LLAMA_MODEL_NAME": "MLX-Qwen3.5-9B-Claude-4.6-Opus-Reasoning-Distilled-v2-8bit"
			}
		}
	]
}